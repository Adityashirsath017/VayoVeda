{
  "expo": {
    "name": "VayoVeda",
    "slug": "vayoveda",
    "owner": "adityashirsath017",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/vayo-app-icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/vayo-app-icon.png",
        "backgroundColor": "#FF6B6B"
      },
      "package": "com.adityashirsath017.vayoveda"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fdabe834-4e32-4626-b17a-20bb186e88a9"
      }
    }
  }
}
